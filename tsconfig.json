{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020", // What JS version to compile to
    "lib": ["ES2020", "DOM", "DOM.Iterable"], // Available APIs (DOM for browser stuff)
    "jsx": "react-jsx", // How to handle JSX

    /* Modules */
    "module": "ESNext", // Use modern import/export syntax
    "moduleResolution": "bundler", // How to resolve imports (bundler for Vite/Webpack)

    /* Type Checking */
    "strict": true, // Enable all strict type-checking options
    "noUnusedLocals": true, // Error on unused variables
    "noUnusedParameters": true, // Error on unused function parameters
    "noImplicitReturns": true, // Error if function doesn't return consistently

    /* Interop Constraints */
    "esModuleInterop": true, // Allow default imports from CommonJS modules
    "allowSyntheticDefaultImports": true, // Allow default imports from modules with no default export
    "forceConsistentCasingInFileNames": true, // Enforce case sensitivity in imports

    /* Skip Lib Check */
    "skipLibCheck": true // Skip type checking of declaration files (faster builds)
  },
  "include": [
    "src/**/*" // Which files to include (all files in src/)
  ],
  "exclude": [
    "node_modules" // Don't check node_modules
  ]
}
